# Copy this file to ".env" and fill in your key.
OPENAI_API_KEY=sk-your-key-here
CHAT_MODEL=gpt-4o-mini
COLLECTION=nssf

# Optional monitoring. Sign up free at https://cloud.langfuse.com,
# create a project, and paste the keys here. Leave blank to skip.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
